---
interface Field {
  name: string;
  bytes: number | string;
  highlight?: boolean;
}

interface Props {
  fields: Field[];
  label?: string;
}

const { fields, label } = Astro.props;

function grow(bytes: number | string): number {
  if (typeof bytes === 'string') return 6;
  return Math.max(bytes, 1);
}
---

<div class="my-6 not-prose">
  {label && (
    <p class="font-mono text-xs text-slate-500 uppercase tracking-widest mb-2">{label}</p>
  )}
  <div class="overflow-x-auto rounded-lg border border-slate-700 bg-slate-900">
    <div class="flex min-w-max">
      {fields.map((field) => (
        <div
          class={`flex flex-col items-center justify-center px-3 py-3 border-r border-slate-700 last:border-r-0 text-center min-w-[56px] ${field.highlight ? 'bg-cyan-950/40' : ''}`}
          style={`flex: ${grow(field.bytes)}`}
        >
          <div class="font-mono text-xs font-semibold text-slate-200 whitespace-nowrap">{field.name}</div>
          <div class="font-mono text-[10px] text-slate-500 mt-1 whitespace-nowrap">
            {typeof field.bytes === 'number' ? `${field.bytes}B` : field.bytes}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
