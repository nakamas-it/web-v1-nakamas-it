---
interface Step {
  from: string;
  to: string;
  label: string;
  sub?: string;
}

interface Props {
  parties: string[];
  steps: Step[];
}

const { parties, steps } = Astro.props;
const [leftParty, rightParty] = parties;
---

<div class="my-8 not-prose rounded-xl border border-slate-800 bg-slate-900/60 overflow-hidden">
  <div class="relative px-6 py-6">

    <!-- Lifelines (absolute, behind content) -->
    <!-- left-16 = 64px = px-6(24px) + w-20/2(40px) -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 bottom-0 w-px bg-slate-700 left-16"></div>
      <div class="absolute top-0 bottom-0 w-px bg-slate-700 right-16"></div>
    </div>

    <!-- Party headers -->
    <div class="flex mb-6">
      <div class="w-20 shrink-0 flex justify-center">
        <span class="font-mono text-xs font-bold text-slate-100 bg-slate-800 border border-slate-600 px-2.5 py-1.5 rounded-lg">
          {leftParty}
        </span>
      </div>
      <div class="flex-1"></div>
      <div class="w-20 shrink-0 flex justify-center">
        <span class="font-mono text-xs font-bold text-slate-100 bg-slate-800 border border-slate-600 px-2.5 py-1.5 rounded-lg">
          {rightParty}
        </span>
      </div>
    </div>

    <!-- Steps -->
    {steps.map((step) => {
      const goingRight = step.from === leftParty;
      return (
        <div class="flex mb-7 last:mb-2">
          <div class="w-20 shrink-0"></div>
          <div class="flex-1">
            <div class="flex items-center">
              {!goingRight && <span class="text-cyan-400 text-xs leading-none">◄</span>}
              <div class="flex-1 h-px bg-cyan-500/50"></div>
              {goingRight && <span class="text-cyan-400 text-xs leading-none">►</span>}
            </div>
            <div class="mt-1.5 text-center">
              <div class="font-mono text-xs font-semibold text-cyan-300">{step.label}</div>
              {step.sub && (
                <div class="font-mono text-xs text-slate-500 mt-0.5">{step.sub}</div>
              )}
            </div>
          </div>
          <div class="w-20 shrink-0"></div>
        </div>
      );
    })}

  </div>
</div>
