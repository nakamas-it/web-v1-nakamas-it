---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Nakamas IT — Networking knowledge base and personal profile',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(path);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Nakamas IT</title>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">

    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-10">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href={base} class="font-mono font-bold text-lg text-cyan-400 hover:text-cyan-300 transition-colors">
          Nakamas IT
        </a>
        <div class="flex gap-8">
          <a
            href={base}
            class={`text-sm font-medium transition-colors ${isActive(base) ? 'text-cyan-400' : 'text-slate-400 hover:text-slate-100'}`}
          >
            Home
          </a>
          <a
            href={`${base}school/`}
            class={`text-sm font-medium transition-colors ${isActive(`${base}school`) ? 'text-cyan-400' : 'text-slate-400 hover:text-slate-100'}`}
          >
            School
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-slate-800 mt-16">
      <div class="max-w-5xl mx-auto px-6 py-8 flex items-center justify-between text-slate-500 text-sm">
        <span class="font-mono">Nakamas IT</span>
        <span>Built with Astro + Tailwind</span>
      </div>
    </footer>

  </body>
</html>
