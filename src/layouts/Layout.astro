---
import '../styles/global.css';
import NavbarLogo from '../components/NavbarLogo.astro';
import { useTranslations } from '../i18n/ui';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
}

const {
  title,
  description = 'Nakamas IT — Networking knowledge base and personal profile',
  lang = 'en',
} = Astro.props;

const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

// Home link and active state are language-aware
const homeHref = lang === 'es' ? `${base}es/` : base;
const homeActive =
  lang === 'es'
    ? currentPath === `${base}es/` || currentPath === `${base}es`
    : currentPath === base || currentPath === base.slice(0, -1);

const schoolActive = currentPath.startsWith(`${base}school`);

// Only add hreflang on pages that have a translated alternate (home pages)
const isHomePage =
  currentPath === base ||
  currentPath === base.slice(0, -1) ||
  currentPath === `${base}es/` ||
  currentPath === `${base}es`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}nakamas-it.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}nakamas-it.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Nakamas IT</title>
    {isHomePage && (
      <>
        <link rel="alternate" hreflang="en" href="https://nakamas-it.com/" />
        <link rel="alternate" hreflang="es" href="https://nakamas-it.com/es/" />
        <link rel="alternate" hreflang="x-default" href="https://nakamas-it.com/" />
      </>
    )}
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nakamas IT" />
    <meta property="og:title" content={`${title} — Nakamas IT`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://nakamas-it.com${currentPath}`} />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} — Nakamas IT`} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">

    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-10">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <NavbarLogo />
        <div class="flex items-center gap-6">
          <div class="flex gap-8">
            <a
              href={homeHref}
              class={`text-sm font-medium transition-colors ${homeActive ? 'text-cyan-400' : 'text-slate-400 hover:text-slate-100'}`}
            >
              {t('nav.home')}
            </a>
            <a
              href={`${base}school/`}
              class={`text-sm font-medium transition-colors ${schoolActive ? 'text-cyan-400' : 'text-slate-400 hover:text-slate-100'}`}
            >
              {t('nav.school')}
            </a>
          </div>
          <div class="flex font-mono text-xs border border-slate-700 rounded overflow-hidden">
            <a
              href={base}
              class={`px-2 py-1 transition-colors ${lang === 'en' ? 'bg-slate-700 text-slate-100' : 'text-slate-500 hover:text-slate-300'}`}
            >EN</a>
            <a
              href={`${base}es/`}
              class={`px-2 py-1 transition-colors ${lang === 'es' ? 'bg-slate-700 text-slate-100' : 'text-slate-500 hover:text-slate-300'}`}
            >ES</a>
          </div>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 pt-12 pb-4">
      <slot />
    </main>

    <footer class="border-t border-slate-800 sticky bottom-0 z-10 bg-slate-950/90 backdrop-blur">
      <div class="max-w-5xl mx-auto px-6 py-8 flex items-center justify-between text-slate-500 text-sm">
        <span class="font-mono">© 2026 Nakamas IT</span>
        <span class="font-mono italic">{t('footer.tagline')}</span>
      </div>
    </footer>

  </body>
</html>
