---
import '../styles/global.css';
import NavbarLogo from '../components/NavbarLogo.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Nakamas IT — Networking knowledge base and personal profile',
} = Astro.props;

const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(path);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}nakamas-it.svg`} />
    <link rel="icon" type="image/x-icon" href={`${base}nakamas-it.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title} — Nakamas IT</title>
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nakamas IT" />
    <meta property="og:title" content={`${title} — Nakamas IT`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://nakamas-it.com${currentPath}`} />
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} — Nakamas IT`} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen flex flex-col">

    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur sticky top-0 z-10">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <NavbarLogo />
        <div class="flex gap-8">
          <a
            href={base}
            class={`text-sm font-medium transition-colors ${isActive(base) ? 'text-cyan-400' : 'text-slate-400 hover:text-slate-100'}`}
          >
            Home
          </a>
          <a
            href={`${base}school/`}
            class={`text-sm font-medium transition-colors ${isActive(`${base}school`) ? 'text-cyan-400' : 'text-slate-400 hover:text-slate-100'}`}
          >
            School
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 pt-12 pb-4">
      <slot />
    </main>

    <footer class="border-t border-slate-800 sticky bottom-0 z-10 bg-slate-950/90 backdrop-blur">
      <div class="max-w-5xl mx-auto px-6 py-8 flex items-center justify-between text-slate-500 text-sm">
        <span class="font-mono">© 2026 Nakamas IT</span>
        <span class="font-mono italic">there is no place like 127.0.0.1</span>
      </div>
    </footer>

  </body>
</html>
