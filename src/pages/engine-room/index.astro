---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;

const allArticles = await getCollection('engineRoom', ({ data }) => !data.draft);

const categoryMeta: Record<string, { label: string; description: string; accent: string; border: string; icon: string }> = {
  identity: {
    label: 'Identity & Directory',
    description: 'Active Directory, Entra ID, Group Policy, hybrid identity — how organisations manage who can access what.',
    accent: 'text-violet-400',
    border: 'border-violet-800',
    icon: '🔑',
  },
  virtualization: {
    label: 'Virtualization',
    description: 'Hypervisors, ESXi, Hyper-V, Proxmox — what a hypervisor actually does and how virtualised infrastructure is built.',
    accent: 'text-blue-400',
    border: 'border-blue-800',
    icon: '📦',
  },
  storage: {
    label: 'Storage',
    description: 'RAID, NAS vs SAN, TrueNAS, ZFS — how enterprise storage is structured, protected, and shared.',
    accent: 'text-amber-400',
    border: 'border-amber-800',
    icon: '💾',
  },
  endpoint: {
    label: 'Endpoint Management',
    description: 'Intune, Group Policy, imaging — how devices are deployed, configured, and kept compliant at scale.',
    accent: 'text-green-400',
    border: 'border-green-800',
    icon: '🖥️',
  },
  email: {
    label: 'Email & Collaboration',
    description: 'Exchange Online, Microsoft 365 tenant concepts — the plumbing behind every calendar invite and shared mailbox.',
    accent: 'text-sky-400',
    border: 'border-sky-800',
    icon: '📧',
  },
  monitoring: {
    label: 'Monitoring & Logging',
    description: "SNMP, Syslog, NetFlow, observability — knowing what your infrastructure is doing before your users tell you it's broken.",
    accent: 'text-rose-400',
    border: 'border-rose-800',
    icon: '📊',
  },
};

const categories = Object.entries(categoryMeta).map(([key, meta]) => ({
  key,
  ...meta,
  articles: allArticles
    .filter(a => a.data.category === key)
    .sort((a, b) => a.data.order - b.data.order),
}));

const totalArticles = allArticles.length;
---

<Layout title="Engine Room" description="The theory layer for platforms and services — what they are, why they exist, and how they work conceptually.">

  <header class="mb-8">
    <h1 class="text-4xl font-bold text-slate-100 mb-4">The Engine Room</h1>
    <p class="text-slate-400 leading-relaxed">
      <span class="text-cyan-400 font-mono font-semibold">WANTED:</span> A straight answer about how enterprise services actually work.
      Last seen buried somewhere between a domain controller with no documentation and a hypervisor that
      someone set up in 2019 and nobody has touched since. This section covers the conceptual layer —
      what these platforms are, why they exist, and how they work before you ever touch a CLI or a GUI.
      Organised by category rather than OSI layer, because Active Directory doesn't care which layer it runs on.
    </p>
  </header>

  <!-- Search bar -->
  <div class="mb-10">
    <div class="relative">
      <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-500 pointer-events-none" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="er-search"
        type="search"
        placeholder={`Search ${totalArticles} articles... (press / to focus)`}
        autocomplete="off"
        spellcheck="false"
        class="w-full bg-slate-900 border border-slate-700 hover:border-slate-600 rounded-xl px-4 py-3 pl-10 pr-10 text-slate-100 placeholder-slate-500 focus:outline-none focus:border-amber-800 focus:ring-1 focus:ring-amber-900 font-mono text-sm transition-colors"
      />
      <button
        id="er-search-clear"
        aria-label="Clear search"
        class="hidden absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-100 transition-colors"
      >
        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" class="w-4 h-4">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <p id="er-search-status" class="hidden mt-2 text-slate-500 text-xs font-mono pl-1"></p>
  </div>

  <div id="er-browser" class="space-y-12">
    {categories.map(cat => (
      <section data-category-section={cat.key}>
        <a
          href={`${base}engine-room/${cat.key}`}
          class={`inline-flex items-center gap-2 text-lg font-semibold mb-1 hover:underline underline-offset-4 ${cat.accent}`}
        >
          <span class="text-base">{cat.icon}</span>
          {cat.label}
          <span class="text-slate-500 text-sm font-normal">→</span>
        </a>
        <p class="text-slate-400 text-sm mb-5">{cat.description}</p>

        {cat.articles.length === 0 ? (
          <p class="text-slate-600 text-sm italic">Articles coming soon.</p>
        ) : (
          <>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {cat.articles.map((article, index) => {
                const [catKey, slug] = article.id.split('/');
                const searchText = [
                  article.data.title,
                  article.data.summary,
                  article.data.topic,
                  ...article.data.tags,
                ].join(' ').toLowerCase();
                const isExtra = index >= 2;
                return (
                  <a
                    href={`${base}engine-room/${catKey}/${slug}`}
                    data-article-card
                    data-search-text={searchText}
                    data-extra={isExtra ? 'true' : undefined}
                    style={isExtra ? 'display:none' : ''}
                    class={`bg-slate-900 border ${cat.border} hover:border-opacity-60 rounded-xl p-5 transition-colors group`}
                  >
                    <div class="flex items-center justify-between gap-3 mb-2">
                      <p class="text-slate-100 text-sm font-semibold leading-snug group-hover:underline underline-offset-2">{article.data.title}</p>
                      <span class={`font-mono text-xs font-bold shrink-0 px-2 py-1 rounded border border-current opacity-60 ${cat.accent}`}>
                        {article.data.topic.toUpperCase()}
                      </span>
                    </div>
                    <p class="text-slate-400 text-xs leading-relaxed">{article.data.summary}</p>
                  </a>
                );
              })}
            </div>
            {cat.articles.length > 2 && (
              <div class="mt-3 text-right" data-see-all>
                <a
                  href={`${base}engine-room/${cat.key}`}
                  class={`text-sm font-medium hover:underline underline-offset-4 ${cat.accent}`}
                >
                  See all {cat.articles.length} articles →
                </a>
              </div>
            )}
          </>
        )}
      </section>
    ))}
  </div>

  <p id="er-search-empty" class="hidden text-slate-500 text-center py-20 font-mono text-sm">
    No articles match your search.
  </p>

</Layout>

<script>
  const input = document.getElementById('er-search') as HTMLInputElement;
  const clearBtn = document.getElementById('er-search-clear') as HTMLButtonElement;
  const statusEl = document.getElementById('er-search-status') as HTMLParagraphElement;
  const emptyEl = document.getElementById('er-search-empty') as HTMLParagraphElement;
  const sections = document.querySelectorAll<HTMLElement>('[data-category-section]');

  function applyFilter(q: string) {
    const lower = q.toLowerCase().trim();
    clearBtn.classList.toggle('hidden', !lower);

    let totalMatches = 0;

    sections.forEach(section => {
      const cards = section.querySelectorAll<HTMLElement>('[data-article-card]');
      const seeAll = section.querySelector<HTMLElement>('[data-see-all]');
      let sectionMatches = 0;

      cards.forEach(card => {
        const text = card.dataset.searchText ?? '';
        const isExtra = card.dataset.extra === 'true';

        if (!lower) {
          card.style.display = isExtra ? 'none' : '';
        } else {
          const match = text.includes(lower);
          card.style.display = match ? '' : 'none';
          if (match) sectionMatches++;
        }
      });

      if (!lower) {
        if (seeAll) seeAll.style.display = '';
        section.style.display = '';
      } else {
        if (seeAll) seeAll.style.display = 'none';
        totalMatches += sectionMatches;
        section.style.display = sectionMatches > 0 ? '' : 'none';
      }
    });

    if (lower) {
      statusEl.classList.remove('hidden');
      statusEl.textContent = totalMatches === 0
        ? 'No results.'
        : `${totalMatches} article${totalMatches !== 1 ? 's' : ''} matching "${lower}"`;
      emptyEl.classList.toggle('hidden', totalMatches > 0);
    } else {
      statusEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
    }
  }

  input.addEventListener('input', () => applyFilter(input.value));

  clearBtn.addEventListener('click', () => {
    input.value = '';
    applyFilter('');
    input.focus();
  });

  document.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === '/' && document.activeElement !== input && !(document.activeElement instanceof HTMLInputElement)) {
      e.preventDefault();
      input.focus();
    }
    if (e.key === 'Escape' && document.activeElement === input) {
      input.value = '';
      applyFilter('');
      input.blur();
    }
  });
</script>
