---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allArticles = await getCollection('engineRoom', ({ data }) => !data.draft);
  const categories = [...new Set(allArticles.map(a => a.data.category))];
  return categories.map(category => ({
    params: { category },
    props: {
      articles: allArticles
        .filter(a => a.data.category === category)
        .sort((a, b) => a.data.order - b.data.order),
    },
  }));
}

const { category } = Astro.params;
const { articles } = Astro.props;
const base = import.meta.env.BASE_URL;

const categoryMeta: Record<string, { label: string; description: string; accent: string; icon: string }> = {
  microsoft: {
    label: 'Microsoft',
    description: 'Windows Server, Active Directory, Hyper-V, Azure Arc, Intune, Microsoft 365 — the full Microsoft infrastructure stack from domain controllers and Group Policy to hybrid cloud and containers.',
    accent: 'text-blue-400',
    icon: '🪟',
  },
  vmware: {
    label: 'VMware',
    description: "ESXi, vSphere, vCenter, vSAN, NSX-T — VMware's virtualisation platform from bare-metal hypervisors to software-defined networking and storage.",
    accent: 'text-green-400',
    icon: '💠',
  },
  linux: {
    label: 'Linux',
    description: 'Debian, Ubuntu, RHEL — open-source server administration, filesystems, LVM, Samba, OpenLDAP, and the tools that run most of the internet.',
    accent: 'text-yellow-400',
    icon: '🐧',
  },
  google: {
    label: 'Google',
    description: 'Google Cloud Platform, Google Workspace — GCP compute, Cloud DNS, Cloud Storage, GKE, and the Google productivity suite for enterprise environments.',
    accent: 'text-red-400',
    icon: '☁️',
  },
  proxmox: {
    label: 'Proxmox',
    description: 'Proxmox VE — the open-source hypervisor combining KVM virtualisation and LXC containers with Ceph storage and high-availability clustering.',
    accent: 'text-orange-400',
    icon: '🔶',
  },
};

const meta = categoryMeta[category!] ?? { label: category, description: '', accent: 'text-amber-400', icon: '⚙️' };
---

<Layout title={meta.label}>

  <nav class="font-mono text-sm text-slate-500 mb-8">
    <a href={`${base}`} class="hover:text-slate-300 transition-colors">home</a>
    <span class="mx-2">/</span>
    <a href={`${base}engine-room`} class="hover:text-slate-300 transition-colors">engine-room</a>
    <span class="mx-2">/</span>
    <span class={meta.accent}>{category}</span>
  </nav>

  <header class="mb-12">
    <h1 class={`text-4xl font-bold mb-3 ${meta.accent}`}>
      <span class="mr-2">{meta.icon}</span>{meta.label}
    </h1>
    <p class="text-slate-400 leading-relaxed">{meta.description}</p>
  </header>

  {articles.length === 0 ? (
    <p class="text-slate-500 italic">No articles yet — check back soon.</p>
  ) : (
    <div class="space-y-4">
      {articles.map(article => {
        const [catKey, slug] = article.id.split('/');
        return (
          <a
            href={`${base}engine-room/${catKey}/${slug}`}
            class="block bg-slate-900 border border-slate-800 hover:border-slate-600 rounded-xl p-6 transition-colors group"
          >
            <div class="flex items-center justify-between gap-3 mb-2">
              <h2 class="min-w-0 font-semibold text-slate-100 group-hover:underline underline-offset-2">
                {article.data.title}
              </h2>
              <span class={`font-mono text-xs font-bold shrink-0 px-2 py-1 rounded border border-current opacity-60 ${meta.accent}`}>
                {article.data.topic.toUpperCase()}
              </span>
            </div>
            <p class="text-slate-400 text-sm leading-relaxed mb-3">{article.data.summary}</p>
            <div class="flex flex-wrap gap-2">
              {article.data.tags.map((tag: string) => (
                <span class="font-mono text-xs text-slate-500 bg-slate-800 px-2 py-0.5 rounded">{tag}</span>
              ))}
            </div>
          </a>
        );
      })}
    </div>
  )}

</Layout>
