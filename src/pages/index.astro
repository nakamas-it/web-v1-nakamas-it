---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const experience = [
  {
    company: 'Nakamas IT',
    type: 'Permanent Full-time',
    location: 'Vancouver, BC, Canada',
    roles: [
      { title: 'Hackerman', period: 'Jan 2026 – Present' },
    ],
  },
  {
    company: "Nature's Path Foods",
    type: 'Permanent Full-time',
    location: 'Richmond, BC, Canada',
    roles: [
      { title: 'IT Operations Manager', period: 'Mar 2026 – Present' },
      { title: 'Systems Administrator', period: 'Nov 2024 – Mar 2026' },
    ],
  },
  {
    company: 'Quicktech',
    type: 'Permanent Full-time',
    location: 'Vancouver, BC, Canada',
    roles: [
      { title: 'Systems Administrator', period: 'Jan 2022 – Nov 2024' },
      { title: 'Support Technician', period: 'Nov 2020 – Jan 2022' },
    ],
  },
  {
    company: 'British Columbia Institute of Technology',
    type: 'Contract Part-time',
    location: 'Vancouver, BC, Canada',
    roles: [
      { title: 'Course Instructor', period: 'Jan 2023 – Apr 2023' },
      { title: 'Teacher Assistant', period: 'Oct 2022 – Jan 2023' },
    ],
  },
  {
    company: 'Temenos',
    type: 'Permanent Full-time',
    location: 'Quito, Ecuador',
    roles: [
      { title: 'Technical Consultant', period: 'Mar 2018 – Dec 2018' },
    ],
  },
  {
    company: 'Conectividad Global SA',
    type: 'Permanent Full-time',
    location: 'Quito, Ecuador',
    roles: [
      { title: 'Full Stack Developer', period: 'Aug 2017 – Dec 2018' },
    ],
  },
  {
    company: 'Pontificia Universidad Católica del Ecuador',
    type: 'Contract Part-time',
    location: 'Quito, Ecuador',
    roles: [
      { title: 'IT Technical Assistant', period: 'Jan 2015 – Jun 2017' },
    ],
  },
];
---

<Layout title="Home" description="Gianfranco Cisneros — technology enthusiast, systems administrator, and networking geek based in Canada.">

  <!-- Hero -->
  <section class="mb-20">
    <p class="font-mono text-cyan-400 text-sm mb-3">Hello, I'm</p>
    <h1 class="text-5xl font-bold text-slate-100 mb-2">Gianfranco Cisneros</h1>
    <p class="font-mono text-slate-500 text-sm mb-6">
      Hackerman, of House Nakamas IT. First of his name. Admin of the systems, and the techs, and protector of the realm.
    </p>
    <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
      Technology enthusiast, systems administrator, and networking geek based in Canada.
      I run <span class="text-slate-200 font-medium">Nakamas IT</span> and use this site
      to share everything I've learned — from packet captures to production deployments.
    </p>
    <div class="flex flex-wrap gap-4 mt-8">
      <a
        href={`${base}school/`}
        class="bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
      >
        Browse the School
      </a>
      <a
        href="#about"
        class="border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-100 font-medium px-6 py-3 rounded-lg transition-colors text-sm"
      >
        About Me
      </a>
      <a
        href="https://www.linkedin.com/in/gianfranco-cisneros-barreiro/"
        target="_blank"
        rel="noopener noreferrer"
        class="border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-100 font-medium px-6 py-3 rounded-lg transition-colors text-sm"
      >
        LinkedIn ↗
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="mb-16 scroll-mt-24">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      About
    </h2>
    <div class="text-slate-400 space-y-4 leading-relaxed max-w-3xl">
      <p>
        Nakamas IT started as a personal project to understand how IT actually works in a business
        context — not just in theory, but by deploying and running the same types of workloads that
        organizations rely on every day.
      </p>
      <p>
        What began as a home lab has gradually evolved into something closer to a small production
        environment. That shift has been one of the most valuable learning experiences I've had,
        because running something for real — with real consequences when it breaks — teaches you
        things that no textbook lab ever could.
      </p>
      <p>
        This site is the natural extension of that. The School section exists to share what I've
        learned through those real-world deployments, explained in a way that connects the dots
        between how a protocol works on paper and what you actually see in a packet capture or a
        production incident.
      </p>
    </div>
  </section>

  <!-- Passions -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      Interests
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {[
        {
          icon: '📡',
          label: 'Networking',
          desc: 'Fluent in TCP/IP and unreasonably excited about a clean Wireshark capture. I read routing tables for fun and consider a well-tuned OSPF topology a form of art.',
        },
        {
          icon: '🛡️',
          label: 'Cybersecurity',
          desc: 'Defender by day, threat hunter by night. Zero-trust, defense-in-depth, EDR, and the thrill of tracing a lateral movement path through event logs at 2am.',
        },
        {
          icon: '🖥️',
          label: 'Servers & Hypervisors',
          desc: 'Baremetal whisperer. Hyper-V clusters, iDRAC consoles, storage pools, and the deeply satisfying sound of rack rails clicking into place.',
        },
        {
          icon: '☁️',
          label: 'Cloud',
          desc: 'Microsoft 365 admin and recovering on-prem purist. Entra ID, Intune, Exchange Online, Defender — yes, I know the cloud is just someone else\'s server. I try to know that person pretty well.',
        },
      ].map(item => (
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
          <div class="text-2xl mb-3">{item.icon}</div>
          <h3 class="font-semibold text-slate-100 mb-1">{item.label}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      Experience
    </h2>
    <div class="space-y-8 max-w-3xl">
      {experience.map(job => (
        <div class="border-l-2 border-slate-700 pl-5">
          <div class="flex items-baseline justify-between gap-4 flex-wrap mb-1">
            <h3 class="font-semibold text-slate-100">{job.company}</h3>
            <span class="font-mono text-xs text-slate-500 shrink-0">{job.type}</span>
          </div>
          <p class="text-slate-500 text-xs font-mono mb-3">{job.location}</p>
          <div class="space-y-2">
            {job.roles.map(role => (
              <div class="flex items-baseline justify-between gap-4 flex-wrap">
                <span class="text-cyan-400 text-sm font-medium">{role.title}</span>
                <span class="font-mono text-xs text-slate-500 shrink-0">{role.period}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="mb-16 scroll-mt-24">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      Contact
    </h2>
    <p class="text-slate-400 max-w-2xl leading-relaxed mb-8">
      Have a question, want to collaborate, or just want to talk networking? LinkedIn is the best way to reach me.
    </p>
    <a
      href="https://www.linkedin.com/in/gianfranco-cisneros-barreiro/"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-3 bg-slate-900 border border-slate-700 hover:border-cyan-400 text-slate-100 font-medium px-6 py-4 rounded-xl transition-colors group"
    >
      <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      <span>Gianfranco Cisneros</span>
      <span class="text-slate-500 group-hover:text-cyan-400 transition-colors text-sm">↗</span>
    </a>
  </section>

</Layout>
