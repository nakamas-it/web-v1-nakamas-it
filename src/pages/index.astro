---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Home">

  <!-- Hero -->
  <section class="mb-20">
    <p class="font-mono text-cyan-400 text-sm mb-3">Hello, I'm</p>
    <h1 class="text-5xl font-bold text-slate-100 mb-4">Gustavo Cisneros</h1>
    <p class="text-xl text-slate-400 max-w-2xl leading-relaxed">
      Network engineer and IT enthusiast. I run <span class="text-slate-200 font-medium">Nakamas IT</span>,
      a small managed services practice, and I document everything I learn along the way.
    </p>
    <div class="flex gap-4 mt-8">
      <a
        href={`${base}school`}
        class="bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
      >
        Browse the School
      </a>
      <a
        href="#about"
        class="border border-slate-700 hover:border-slate-500 text-slate-300 hover:text-slate-100 font-medium px-6 py-3 rounded-lg transition-colors text-sm"
      >
        About me
      </a>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="mb-16 scroll-mt-24">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      About
    </h2>
    <div class="text-slate-400 space-y-4 leading-relaxed max-w-3xl">
      <p>
        <!-- TODO: Write your bio here -->
        Placeholder — tell the story of how you got into networking and IT.
        What problems do you enjoy solving? What kind of environments have you worked in?
      </p>
    </div>
  </section>

  <!-- Passions -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      What I care about
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      {[
        { icon: '🌐', label: 'Networking', desc: 'Protocols, packet analysis, and understanding how data actually moves.' },
        { icon: '🔒', label: 'Security', desc: 'Defense-in-depth, zero trust, and making networks harder to break.' },
        { icon: '🧪', label: 'Lab work', desc: 'EVE-NG simulations, Wireshark captures, and hands-on experimentation.' },
      ].map(item => (
        <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
          <div class="text-2xl mb-3">{item.icon}</div>
          <h3 class="font-semibold text-slate-100 mb-1">{item.label}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Experience -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-slate-100 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cyan-400 inline-block"></span>
      Experience
    </h2>
    <div class="space-y-6 max-w-3xl">
      <!-- TODO: Replace with real entries -->
      {[
        {
          role: 'Founder / Network Engineer',
          company: 'Nakamas IT',
          period: '2024 – present',
          desc: 'Placeholder — describe what you do at Nakamas IT.',
        },
        {
          role: 'Previous Role',
          company: 'Previous Company',
          period: '20XX – 20XX',
          desc: 'Placeholder — describe a previous position.',
        },
      ].map(job => (
        <div class="border-l-2 border-slate-700 pl-5">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <h3 class="font-semibold text-slate-100">{job.role}</h3>
            <span class="font-mono text-xs text-slate-500 shrink-0">{job.period}</span>
          </div>
          <p class="text-cyan-400 text-sm mb-2">{job.company}</p>
          <p class="text-slate-400 text-sm leading-relaxed">{job.desc}</p>
        </div>
      ))}
    </div>
  </section>

</Layout>
